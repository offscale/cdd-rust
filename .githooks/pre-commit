#!/usr/bin/env bash
set -e

echo "Running pre-commit checks..."

echo "Auto-formatting code..."
cargo fmt --all

echo "Checking formatting..."
cargo fmt --all -- --check

# Stage formatting changes if any
if ! git diff --quiet -- '*.rs'; then
    echo "Formatting changed some files, staging them..."
    # get all changed files matching .rs and stage them
    git diff --name-only | grep '\.rs$' | xargs -r git add
fi

echo "Building workspace..."
cargo build --workspace --all-targets

echo "Testing workspace..."
cargo test --workspace

echo "Running clippy..."
cargo clippy --workspace --all-targets --all-features -- -D warnings

echo "Running Swagger 2.0 Petstore test..."
cargo run -p cdd-cli -- from_openapi to_sdk -i ../petstore.json -o ./target/petstore2

echo "Running OpenAPI 3.2.0 Petstore test..."
cargo run -p cdd-cli -- from_openapi to_sdk -i ../petstore_oas3.json -o ./target/petstore3

echo "Running WASM build test..."
if command -v make >/dev/null 2>&1; then
    make build_wasm
elif [ -f "./make.bat" ]; then
    ./make.bat build_wasm
else
    echo "Make not found, unable to run WASM build test."
    exit 1
fi

echo "Calculating test coverage..."
if ! cargo tarpaulin --version > /dev/null 2>&1; then
    echo "Warning: cargo-tarpaulin is not installed. Test coverage will be 0.00%."
    echo "Install it with: cargo install cargo-tarpaulin"
fi
TEST_OUTPUT=$(cargo tarpaulin --workspace 2>&1 || true)
TEST_COV=$(echo "$TEST_OUTPUT" | grep -oE '[0-9]+\.[0-9]+% coverage' | grep -oE '[0-9]+\.[0-9]+' | head -n 1 || echo "0.00")

if [ -z "$TEST_COV" ]; then
    TEST_COV="0.00"
fi

echo "Test coverage: $TEST_COV%"

echo "Calculating doc coverage..."
if ! cargo +nightly --version > /dev/null 2>&1; then
    echo "Warning: nightly toolchain is not installed. Doc coverage will be 0.00%."
    echo "Install it with: rustup toolchain install nightly"
fi

# List all workspace packages
PACKAGES=$(cargo tree --workspace --depth 0 | grep -E '^[a-zA-Z0-9_-]+ v[0-9.]+' | cut -d ' ' -f 1)

TOTAL_DOCS=0
DOCUMENTED=0

for pkg in $PACKAGES; do
    DOC_OUTPUT=$(cargo +nightly rustdoc -p "$pkg" -- -Z unstable-options --show-coverage 2>&1 || true)
    TOTAL_LINE=$(echo "$DOC_OUTPUT" | grep "^| Total" || true)
    if [ -n "$TOTAL_LINE" ]; then
        PKG_TOTAL=$(echo "$TOTAL_LINE" | awk -F'|' '{print $3}' | tr -d ' ')
        PKG_DOC_PCT=$(echo "$TOTAL_LINE" | awk -F'|' '{print $4}' | tr -d ' %')
        
        TOTAL_DOCS=$(echo "$TOTAL_DOCS + $PKG_TOTAL" | bc)
        DOCUMENTED=$(echo "$DOCUMENTED + ($PKG_TOTAL * $PKG_DOC_PCT / 100)" | bc -l)
    fi
done

if [ "$TOTAL_DOCS" -eq 0 ]; then
    DOC_COV="0.00"
else
    DOC_COV=$(echo "scale=2; $DOCUMENTED / $TOTAL_DOCS * 100" | bc)
fi

echo "Doc coverage: $DOC_COV%"

# Determine colors
if [ "$(echo "$TEST_COV >= 90" | bc -l)" -eq 1 ]; then
    TEST_COLOR="brightgreen"
elif [ "$(echo "$TEST_COV >= 75" | bc -l)" -eq 1 ]; then
    TEST_COLOR="yellow"
else
    TEST_COLOR="red"
fi

if [ "$(echo "$DOC_COV >= 90" | bc -l)" -eq 1 ]; then
    DOC_COLOR="brightgreen"
elif [ "$(echo "$DOC_COV >= 75" | bc -l)" -eq 1 ]; then
    DOC_COLOR="yellow"
else
    DOC_COLOR="red"
fi

# Update README.md
if [ -f README.md ]; then
    echo "Updating README.md badges..."
    
    # Update Test Coverage badge
    sed -i.bak -E "s/badge\/test_coverage-[0-9.]+%25-[a-zA-Z]+/badge\/test_coverage-${TEST_COV}%25-${TEST_COLOR}/g" README.md
    
    # Update Doc Coverage badge
    sed -i.bak -E "s/badge\/doc_coverage-[0-9.]+%25-[a-zA-Z]+/badge\/doc_coverage-${DOC_COV}%25-${DOC_COLOR}/g" README.md
    
    rm -f README.md.bak
    
    # Check if README.md was changed and stage it
    if ! git diff --quiet README.md; then
        git add README.md
        echo "README.md staged with updated coverage badges."
    fi
fi

echo "Pre-commit checks passed successfully!"
